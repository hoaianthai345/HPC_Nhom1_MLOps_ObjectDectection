FROM serving_pipeline-api:latest

LABEL maintainer="MLOps Team"
LABEL description="Object Detection Gradio UI"

# Set working directory
WORKDIR /app

# The API image already contains Python and image-processing dependencies.
# Install only the UI-specific font package.
RUN apt-get update && apt-get install -y \
    fonts-dejavu-core \
    && rm -rf /var/lib/apt/lists/*

# Copy application code
COPY serving_pipeline /app/serving_pipeline/

# Expose Gradio port
EXPOSE 7860

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:7860 || exit 1

# Run Gradio app
CMD ["python", "-m", "serving_pipeline.gradio_app"]

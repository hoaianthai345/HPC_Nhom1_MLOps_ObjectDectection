# Server Configuration
DEBUG=false
HOST=0.0.0.0
API_PORT=8000
GRADIO_PORT=7860
API_HOST=localhost  # Use 'api' when running in Docker compose

# Image Validation
MAX_FILE_SIZE_MB=10.0
MIN_IMAGE_WIDTH=32
MIN_IMAGE_HEIGHT=32
MAX_IMAGE_WIDTH=4096
MAX_IMAGE_HEIGHT=4096

# YOLO Model Configuration
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
YOLO_MAX_DETECTIONS=100
DEVICE=cpu  # Device for inference: 'cpu' or 'cuda'

# Production Data Storage
PRODUCTION_DIR=/data/production

# Production Data Bucket (for teacher inference)
PRODUCTION_DATA_DIR=/data/production-data

# MinIO Configuration for Production Data
USE_MINIO=true  # Set to false for local filesystem storage
MINIO_ENDPOINT=http://minio:9000
MINIO_PRODUCTION_BUCKET=production-data

# MLflow Integration (if using model registry)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_MODEL_URI=models:/yolo-nano-model/production

# AWS/S3 Credentials (used for both MLflow artifact storage and MinIO)
AWS_ACCESS_KEY_ID=minio_admin
AWS_SECRET_ACCESS_KEY=minio_password123
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# Monitoring
PROMETHEUS_ENABLED=true

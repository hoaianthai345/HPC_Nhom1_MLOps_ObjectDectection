AIRFLOW_UID=50000
MINIO_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minio_admin
AWS_SECRET_ACCESS_KEY=minio_password123
MLFLOW_TRACKING_URI=http://mlflow_server:5000
TRAIN_EPOCHS=10
TRAIN_BATCH_SIZE=16
TRAIN_DEVICE=0

# Model Promotion Thresholds (0.0 to 1.0)
# Model will be promoted to Production if ALL thresholds are met
PROMOTION_MAP50_THRESHOLD=0.5
PROMOTION_MAP50_95_THRESHOLD=0.3
PROMOTION_PRECISION_THRESHOLD=0.4
PROMOTION_RECALL_THRESHOLD=0.4

# TensorRT Conversion Settings
TENSORRT_IMGSZ=640              # Image size for TensorRT engine
TENSORRT_FP16=true              # Use FP16 precision (faster, less accurate)
TENSORRT_DYNAMIC=false          # Dynamic batch size support
TENSORRT_WORKSPACE=4            # Max GPU memory for TensorRT (GB)
TENSORRT_BATCH=1                # Fixed batch size (if not dynamic)
TENSORRT_DEVICE=0               # GPU device ID
TENSORRT_BUCKET=model-exports   # MinIO bucket for TensorRT engines